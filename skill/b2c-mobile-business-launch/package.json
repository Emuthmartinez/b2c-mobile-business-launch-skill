{
  "name": "b2c-mobile-business-launch-skill-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "validate:launch-state": "tsx scripts/validate-project-state.ts",
    "check:attribution": "tsx scripts/check-attribution-contract.ts",
    "check:apple-signing": "tsx scripts/check-apple-signing-packet.ts",
    "check:store-console": "tsx scripts/check-store-console-packet.ts",
    "check:ux-patterns": "tsx scripts/check-ux-patterns.ts",
    "check:secrets": "tsx scripts/check-secret-routing.ts",
    "audit:links": "tsx scripts/audit-skill-links.ts --skill-root .",
    "render:launch-cockpit": "tsx scripts/render-launch-cockpit.ts",
    "test:validators": "tsx scripts/run-validator-fixtures.ts",
    "launchbench": "tsx scripts/run-launchbench.ts",
    "audit": "npm exec tsc -- --noEmit && npm run audit:links && npm run launchbench && npm run validate:launch-state -- --root templates --state PROJECT_STATE.yaml && npm run check:ux-patterns -- --root templates --state PROJECT_STATE.yaml && npm run render:launch-cockpit -- --root templates --state PROJECT_STATE.yaml --out /tmp/b2c-launch-cockpit.html"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "yaml": "^2.6.1"
  }
}
