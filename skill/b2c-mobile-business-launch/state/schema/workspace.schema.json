{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:business-control-plane:workspace:0.1.0",
  "title": "Business Control Plane Workspace",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "updatedAt", "product", "businesses", "templates"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "updatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}(?:T[\\d:.+-]+Z?)?$"
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "subtitle"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "subtitle": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "businesses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/business"
      }
    },
    "templates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/template"
      }
    }
  },
  "$defs": {
    "business": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "type",
        "updated",
        "badge",
        "mark",
        "subtitle",
        "metrics",
        "readiness",
        "agents",
        "lanes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "updated": {
          "type": "string",
          "minLength": 1
        },
        "badge": {
          "type": "string",
          "minLength": 1
        },
        "mark": {
          "type": "string",
          "minLength": 1,
          "maxLength": 3
        },
        "subtitle": {
          "type": "string",
          "minLength": 1
        },
        "metrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/metric"
          }
        },
        "readiness": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/readiness"
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/agent"
          }
        },
        "lanes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lane"
          }
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value", "note"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string"
        }
      }
    },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "label", "tag"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["green", "amber", "red", "quiet"]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "summary"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary", "path", "status"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["Ready", "Watch", "Draft", "Gate", "Active", "Blocked"]
        }
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "summary", "included"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "included": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
