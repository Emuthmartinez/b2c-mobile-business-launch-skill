{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:b2c-mobile-business-launch:business-schema",
  "title": "B2C Mobile Business Design Room State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "updatedAt",
    "business",
    "theme",
    "designRoom",
    "surfaces",
    "controlPlane"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "updatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}(?:T[\\d:.+-]+Z?)?$"
    },
    "business": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "slug",
        "stage",
        "positioning",
        "targetAudience"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "slug": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "stage": {
          "type": "string",
          "enum": [
            "concept",
            "research",
            "design",
            "build",
            "prelaunch",
            "launch",
            "postlaunch"
          ]
        },
        "positioning": {
          "type": "string"
        },
        "targetAudience": {
          "type": "string"
        }
      }
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokensPath",
        "status"
      ],
      "properties": {
        "tokensPath": {
          "type": "string",
          "const": "state/theme.tokens.json"
        },
        "status": {
          "type": "string",
          "enum": [
            "provisional",
            "draft",
            "approved"
          ]
        }
      }
    },
    "designRoom": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "renderPath",
        "versionLog",
        "baselines"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "not_started",
            "mutating",
            "rendered",
            "baselined",
            "blocked"
          ]
        },
        "renderPath": {
          "type": "string",
          "minLength": 1
        },
        "versionLog": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/versionEntry"
          }
        },
        "baselines": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/baseline"
          }
        }
      }
    },
    "surfaces": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "webFunnels",
        "landingPages",
        "marketingAssets",
        "mobileApp",
        "appStore"
      ],
      "properties": {
        "webFunnels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface"
          }
        },
        "landingPages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface"
          }
        },
        "marketingAssets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface"
          }
        },
        "mobileApp": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "platforms",
            "screens",
            "flows"
          ],
          "properties": {
            "platforms": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "ios",
                  "android",
                  "web"
                ]
              }
            },
            "screens": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/surface"
              }
            },
            "flows": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/flow"
              }
            }
          }
        },
        "appStore": {
          "$ref": "#/$defs/appStore"
        }
      }
    },
    "controlPlane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "panels",
        "futurePanels"
      ],
      "properties": {
        "panels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/panel"
          }
        },
        "futurePanels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "status",
        "purpose",
        "decisions",
        "tokenReferences"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "not_started",
            "draft",
            "ready",
            "blocked",
            "not_needed"
          ]
        },
        "purpose": {
          "type": "string"
        },
        "decisions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tokenReferences": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(color|font|radius|space|motion)\\.[A-Za-z0-9.]+$"
          }
        }
      }
    },
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "status",
        "steps",
        "tokenReferences"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "not_started",
            "draft",
            "ready",
            "blocked",
            "not_needed"
          ]
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tokenReferences": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "appStore": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultProductPage",
        "customProductPages",
        "productPageOptimizationTests",
        "inAppEvents"
      ],
      "properties": {
        "defaultProductPage": {
          "$ref": "#/$defs/productPage"
        },
        "customProductPages": {
          "type": "array",
          "maxItems": 70,
          "items": {
            "$ref": "#/$defs/customProductPage"
          }
        },
        "productPageOptimizationTests": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/productPageOptimizationTest"
          }
        },
        "inAppEvents": {
          "type": "array",
          "maxItems": 15,
          "items": {
            "$ref": "#/$defs/inAppEvent"
          }
        }
      }
    },
    "productPage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "positioning",
        "screenshotCount",
        "appPreviewCount",
        "promotionalText",
        "keywords"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "not_started",
            "draft",
            "ready",
            "in_review",
            "approved",
            "published",
            "blocked",
            "not_needed"
          ]
        },
        "positioning": {
          "type": "string"
        },
        "screenshotCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "appPreviewCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "promotionalText": {
          "type": "string",
          "maxLength": 170
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "customProductPage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "positioning",
        "screenshotCount",
        "appPreviewCount",
        "promotionalText",
        "keywords",
        "audience",
        "trafficSource",
        "measurementPlan",
        "shareUrl"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "status": {
          "type": "string",
          "enum": [
            "not_started",
            "draft",
            "ready",
            "in_review",
            "approved",
            "published",
            "blocked",
            "not_needed"
          ]
        },
        "positioning": {
          "type": "string"
        },
        "screenshotCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "appPreviewCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "promotionalText": {
          "type": "string",
          "maxLength": 170
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "audience": {
          "type": "string"
        },
        "trafficSource": {
          "type": "string"
        },
        "measurementPlan": {
          "type": "string"
        },
        "shareUrl": {
          "type": "string"
        },
        "deepLink": {
          "type": "string"
        }
      }
    },
    "productPageOptimizationTest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "hypothesis",
        "trafficAllocationPercent",
        "durationDays",
        "treatments",
        "winnerConfidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "status": {
          "type": "string",
          "enum": [
            "not_started",
            "draft",
            "running",
            "complete",
            "applied",
            "blocked"
          ]
        },
        "hypothesis": {
          "type": "string"
        },
        "trafficAllocationPercent": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "durationDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 90
        },
        "treatments": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "changedAssets"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "changedAssets": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "app_icon",
                    "screenshots",
                    "app_previews"
                  ]
                }
              }
            }
          }
        },
        "winnerConfidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "inAppEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "referenceName",
        "status",
        "purpose",
        "schedule",
        "deepLink",
        "requiresIap",
        "mediaStatus"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "referenceName": {
          "type": "string",
          "maxLength": 64
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "in_review",
            "approved",
            "published",
            "past",
            "blocked"
          ]
        },
        "purpose": {
          "type": "string"
        },
        "schedule": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "startsAt",
            "endsAt"
          ],
          "properties": {
            "startsAt": {
              "type": "string"
            },
            "endsAt": {
              "type": "string"
            }
          }
        },
        "deepLink": {
          "type": "string"
        },
        "requiresIap": {
          "type": "boolean"
        },
        "mediaStatus": {
          "type": "string",
          "enum": [
            "not_started",
            "draft",
            "ready",
            "blocked"
          ]
        }
      }
    },
    "panel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "status",
        "stateRefs",
        "renderedArtifacts"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "planned",
            "blocked",
            "not_needed"
          ]
        },
        "stateRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "renderedArtifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "versionEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "createdAt",
        "summary",
        "statePaths",
        "renderedArtifacts"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "statePaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "renderedArtifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "gitRef",
        "createdAt"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "gitRef": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      }
    }
  }
}
